# OpenFamHub — environment / secrets
# Copy to `.env` (gitignored) and fill in. Leave blank to run in fallback/demo mode.
#   cp .env.example .env

# --- Timezone (avoids a startup warning; used by both containers) ---
# Must be a real IANA zone name (e.g. `America/Los_Angeles`, not `America/Portland` —
# that's not a valid tzdata entry). An invalid value doesn't error; Node silently
# treats local time as UTC, which broke the "completed today" midnight cutoff.
TZ=America/New_York

# --- Sleep schedule (app-level blackout, NOT xset dpms) ---
# 24h clock, local time. Wraps past midnight automatically (22 -> 7 = asleep
# 10pm-7am). Manual sleep (Home screen button) works regardless of this window.
# These (and the screensaver timings below) are only the FRESH-INSTALL defaults:
# once someone saves the wall's Settings screen (parent-PIN gated), the saved
# value lives in the database and wins over these.
SLEEP_START_HOUR=22
SLEEP_END_HOUR=7

# --- Screensaver timings (same DB-overrides-env rule as the sleep hours) ---
# Idle minutes before the photo slideshow starts, and seconds per photo.
SCREENSAVER_IDLE_MIN=3
SCREENSAVER_CYCLE_SEC=20

# --- Todoist (Phase 3: tap-to-complete To-do & Routine·Chore) ---
# Get a token at: Todoist → Settings → Integrations → Developer → API token
TODOIST_TOKEN=

# --- Per-member Tasks screens (To-do + Routine·Chore tabs) ---
# Two SHARED Todoist projects, each split by assignee. Every family member —
# parents AND kids — is a collaborator with their own account, so tasks can be
# assigned per person. TODOIST_TODO_PROJECT also feeds the Home "To Do" card
# (as a flat summary). Set these to match your project names:
TODOIST_TODO_PROJECT=todos
TODOIST_ROUTINE_PROJECT=chores
# The roster (who exists, their ids/names/colors) lives in config/members.json —
# copy config/members.example.json to start; any number of members, any ids.
# For each member id in that file, set its Todoist user id and PWA PIN below
# (uppercased id: e.g. id "kid1" -> TODOIST_UID_KID1 / MEMBER_PIN_KID1). After
# setting the token + the two projects above, discover ids with:
#   curl -s localhost:8080/api/todoist/collaborators
# Blank UID = that person stays on demo data. Example for the default roster:
TODOIST_UID_DAD=
TODOIST_UID_MOM=
TODOIST_UID_KID1=
TODOIST_UID_KID2=

# --- Companion PWA login (Phase 6) — 4-digit PIN per member (same <ID> pattern
# as above), required for mobile login (the wall itself stays login-free).
# Blank = that person can't log in on mobile. Reachable only over Tailscale —
# the network layer is the real access control, the PIN is defense-in-depth,
# not the primary boundary.
MEMBER_PIN_DAD=
MEMBER_PIN_MOM=
MEMBER_PIN_KID1=
MEMBER_PIN_KID2=

# --- Network exposure ---
# Which host interfaces publish port 8080. Default (blank) = every interface,
# reachable from your whole LAN — fine for a home network you trust.
# Set to 127.0.0.1 to make the app reachable only from this host itself (the
# kiosk's own browser still works via localhost); pair that with
# `tailscale serve --bg --tcp 8080 tcp://127.0.0.1:8080` on the host so your
# tailnet (not plain LAN wifi/guest network) can still reach it. See
# docs/deployment/self-hosting.md.
BIND_ADDR=

# --- Budget tab PIN gate ---
# The wall stays login-free everywhere except Budget: comma-separated member
# ids (matching config/members.json) who can enter their PIN (from
# MEMBER_PIN_<ID> above) to view finances on the wall. Defaults to dad,mom —
# override if your roster uses different ids. Each of these members needs a
# MEMBER_PIN_<ID> set above, or they'll have no PIN to unlock it with.
BUDGET_UNLOCK_MEMBERS=dad,mom

# --- Weather (built-in module, Open-Meteo — free, no API key/signup) ---
# 10-day forecast; leave lat/lon blank to show a setup placeholder.
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_UNITS=imperial
WEATHER_PLACE=

# --- Calendar ---
# For Google events use each calendar's "Secret address in iCal format"
#   (Google Calendar → Settings → Settings for my calendars → <calendar> →
#   Integrate calendar → "Secret address in iCal format").
#   NOTE: the Todoist iCal export only exports Todoist TASKS, not your Google calendars.
#
# Two kinds, same <ID> pattern as TODOIST_UID_<ID> / MEMBER_PIN_<ID> above:
#   CALENDAR_ICS_URL_<ID>  a member's own feed(s) — every event maps to that
#                          person (Day view's per-person column) and takes
#                          their roster color. Set one per person who has a
#                          personal calendar; leave the rest blank.
#   CALENDAR_ICS_URL       shared feed(s) nobody in particular owns (e.g. a
#                          family events calendar) — shows in Day view's
#                          "Everyone" column instead of a specific person's.
# Either accepts one or more URLs, separated by ";". Blank = falls back to
# bundled demo events (same as any other unconfigured source).
CALENDAR_ICS_URL_DAD=
CALENDAR_ICS_URL_MOM=
CALENDAR_ICS_URL_KID1=
CALENDAR_ICS_URL_KID2=
CALENDAR_ICS_URL=

# --- Monarch Money (Phase 4: financial snapshot sidecar) ---
# Leave blank to render a sample/demo budget table instead of live data.
MONARCH_EMAIL=
MONARCH_PASSWORD=
# Optional: if your Monarch login uses MFA, paste the TOTP *secret* (not a 6-digit code)
# so the sidecar can generate codes itself. Otherwise leave blank.
MONARCH_TOTP_SECRET=
# How often (minutes) the sidecar refreshes the budget snapshot:
FETCH_INTERVAL_MIN=30

# --- Mealie (Meals screen — weekly plan, recipes, single grocery list) ---
# Self-hosted recipe manager, run separately (e.g. on a homelab box). Leave
# blank to render demo meal data instead of live data.
#   MEALIE_URL: base URL of your Mealie instance, no trailing slash
#   MEALIE_TOKEN: Mealie → Settings → API Tokens → create a long-lived token
MEALIE_URL=
MEALIE_TOKEN=
# Optional: browser-facing Mealie URL for the companion PWA's "Meals" launcher
# tab. Set this to the HTTPS URL you reach Mealie at from your phone (e.g. the
# ts.net URL from `tailscale serve`) — NOT the MEALIE_URL above, which is how
# the container reaches Mealie. Blank = the Meals tab stays hidden. URL only, no
# token, so it's safe to hand to the client.
MEALIE_APP_URL=

# --- Screensaver photos ---
# No env var needed — drop image files (.jpg/.jpeg/.png/.webp) into data/photos/
# on the host. Empty folder falls back to a dark ambient clock face. (Not Google
# Photos: Google locked that API down in 2025 in a way that doesn't work for an
# always-on kiosk — see docs/user-guide for details.)

# --- Web push notifications (companion PWA) ---
# Chore reminder + dinner digest to the parents' phones. Needs two things:
#   1. VAPID keys — generate ONCE with `npx web-push generate-vapid-keys`
#      and paste both below. Blank = push quietly disabled.
#   2. HTTPS — browsers only allow push from a secure context, so reach the
#      PWA through `tailscale serve` HTTPS mode (free ts.net certificate),
#      not plain http://<ip>:8080. See docs/deployment/self-hosting.md.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Who receives the scheduled notifications (comma-separated member ids):
PUSH_MEMBERS=dad,mom
# When to send, 24h local hour: chores still open (morning), tonight's dinner.
CHORE_REMINDER_HOUR=8
DINNER_DIGEST_HOUR=17
# Per-notification kill-switches (0/1) — fresh-install defaults only; the
# wall's Settings screen (parent-PIN gated) has toggles that override these.
PUSH_CHORE_REMINDER=1
PUSH_DINNER_DIGEST=1

# --- Chore celebration ---
# Confetti + a synth chime when a kid (member with "kid": true) marks a chore
# done. 0/1; fresh-install default only — the Settings screen toggle overrides.
CELEBRATE_CHORES=1

# --- Weekly/monthly recap ---
# Auto-posted into the Journal (tag "Recap") Sundays + the 1st, at this hour:
RECAP_HOUR=19

# --- Presence sensor (optional, future hardware) ---
# A PIR/mmWave sensor can POST {"present":true|false} to /api/presence to wake
# the screensaver. If set, the sensor must send this as an X-Presence-Token
# header; blank = no token required (fine on a trusted LAN).
PRESENCE_TOKEN=
